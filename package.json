{
  "name": "@truss-security/truss-sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for the Truss API",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "truss": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "example": "tsx src/cli.ts examples",
    "example:basic": "tsx examples/basic-search.ts",
    "example:typed-filter": "tsx examples/typed-filter-search.ts",
    "example:iterate": "tsx examples/iterate-products.ts",
    "example:smart": "tsx examples/smart-agent-search.ts",
    "example:stix": "tsx examples/stix-search.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "truss",
    "api",
    "sdk",
    "typescript",
    "threat-intelligence",
    "search",
    "stix"
  ],
  "author": "Truss",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "jsep": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ]
}
